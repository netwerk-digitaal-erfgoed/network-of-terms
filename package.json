{
  "name": "network-of-terms",
  "private": true,
  "workspaces": [
    "./packages/*"
  ],
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.3.0",
    "@nx/docker": "22.5.4",
    "@nx/esbuild": "22.5.4",
    "@nx/eslint": "22.5.4",
    "@nx/eslint-plugin": "22.5.4",
    "@nx/js": "22.5.4",
    "@nx/vite": "22.5.4",
    "@nx/web": "22.5.4",
    "@rdfjs/types": "^2.0.1",
    "@swc-node/core": "^1.14.1",
    "@swc-node/register": "1.11.1",
    "@types/node": "^25.1.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jiti": "2.6.1",
    "jsonc-eslint-parser": "^3.1.0",
    "nodaemon": "^0.0.5",
    "nodemon": "^3.1.11",
    "nx": "22.5.4",
    "prettier": "^3.7.4",
    "prettier-plugin-packagejson": "^3.0.0",
    "tslib": "^2.3.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "nx": {
    "includedScripts": [],
    "targets": {
      "test:coverage": {
        "command": "vitest run",
        "dependsOn": [
          "^build"
        ]
      },
      "local-registry": {
        "executor": "@nx/js:verdaccio",
        "options": {
          "port": 4873,
          "config": ".verdaccio/config.yml",
          "storage": "tmp/local-registry/storage"
        }
      }
    }
  }
}
