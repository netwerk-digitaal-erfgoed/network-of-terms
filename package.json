{
  "name": "network-of-terms",
  "private": true,
  "workspaces": [
    "./packages/*"
  ],
  "devDependencies": {
    "@commitlint/cli": "20.4.2",
    "@commitlint/config-conventional": "20.3.1",
    "@nx/docker": "22.6.2",
    "@nx/esbuild": "22.6.2",
    "@nx/eslint": "22.6.2",
    "@nx/eslint-plugin": "22.6.2",
    "@nx/js": "22.6.2",
    "@nx/vite": "22.6.2",
    "@nx/web": "22.6.2",
    "@rdfjs/types": "2.0.1",
    "@swc-node/core": "1.14.1",
    "@swc-node/register": "1.11.1",
    "@types/node": "25.2.0",
    "@vitest/coverage-v8": "4.0.18",
    "@vitest/ui": "4.0.18",
    "esbuild": "0.27.3",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "husky": "9.1.7",
    "jiti": "2.6.1",
    "jsonc-eslint-parser": "3.1.0",
    "nodaemon": "0.0.5",
    "nodemon": "3.1.11",
    "nx": "22.6.2",
    "prettier": "3.8.1",
    "prettier-plugin-packagejson": "3.0.0",
    "tslib": "2.8.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1",
    "vitest": "4.0.18"
  },
  "nx": {
    "includedScripts": [],
    "targets": {
      "test:coverage": {
        "command": "vitest run",
        "dependsOn": [
          "^build"
        ]
      },
      "local-registry": {
        "executor": "@nx/js:verdaccio",
        "options": {
          "port": 4873,
          "config": ".verdaccio/config.yml",
          "storage": "tmp/local-registry/storage"
        }
      }
    }
  }
}
